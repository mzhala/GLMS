@model IEnumerable<GLMS.Models.Contract>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create"
       class="custom-btn custom-btn-success">
        Create New
    </a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Client)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StartDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EndDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ServiceLevel)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AgreementFilePath)
            </th>
            <th>
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Client.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StartDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EndDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                 @item.ServiceLevel.ToString()
            </td>
            <td>
                @if (!string.IsNullOrEmpty(item.AgreementFilePath))
                {
                    <a href="~/uploads/contracts/@item.AgreementFilePath"
                        target="_blank"
                        class="custom-btn custom-btn-info">
                        View PDF
                    </a>
                }
            </td>

            <td>
                @if (!string.IsNullOrEmpty(item.AgreementFilePath))
                {
                    <a href="~/uploads/contracts/@item.AgreementFilePath"
                        download
                        class="custom-btn custom-btn-secondary">
                        Download PDF
                    </a>
                }
            </td>
            <td>
                <a asp-action="Edit"
                    asp-route-id="@item.Id"
                    class="custom-btn custom-btn-primary">
                    Edit
                </a>
                    
                <a asp-action="Delete"
                    asp-route-id="@item.Id"
                    class="custom-btn custom-btn-danger">
                    Delete
                </a>
            </td>
        </tr>
}
    </tbody>
</table>
