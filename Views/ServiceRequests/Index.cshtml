@model IEnumerable<GLMS.Models.ServiceRequest>

@{
    ViewData["Title"] = "Index";
}

<h1>Service Request</h1>

<p>
    <a asp-action="Create"
       class="custom-btn custom-btn-success">
        Create New
    </a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Contract.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CostUSD)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CostZAR)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Contract.Id)
            </td>
            
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CostUSD)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CostZAR)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            
            <td>
                <a asp-action="Edit"
                    asp-route-id="@item.Id"
                    class="custom-btn custom-btn-primary">
                    Edit
                </a>

                <a asp-action="Delete"
                    asp-route-id="@item.Id"
                    class="custom-btn custom-btn-danger">
                    Delete
                    </a>
            </td>
        </tr>
}
    </tbody>
</table>
